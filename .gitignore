# ── Node ────────────────────────────────────────────────────────────────────
node_modules/

# ── Local-only config (secrets / per-developer overrides) ────────────────────
.env
.claude/settings.local.json

# ── Build output ─────────────────────────────────────────────────────────────
# `./build.sh` writes store ZIPs to build/<browser>/, and the legacy
# `npm run package` writes <name>-<version>.zip to the project root.
# Both are re-generated on demand, not stored in git.
build/
dist/
*.zip

# Vite cache
.vite/

# ── Test artefacts ───────────────────────────────────────────────────────────
# Created by `npm run test:coverage` — open coverage/lcov-report/index.html locally
coverage/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── IntelliJ IDEA ────────────────────────────────────────────────────────────
# Ignore personal/machine-specific IDE state …
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
.idea/git_toolbox_blame.xml
.idea/git_toolbox_prj.xml
.idea/copilot.data.migration.ask2agent.xml

# … but KEEP .idea/runConfigurations/ so teammates get the npm run buttons
# (nothing extra needed here — the folder is tracked by default once the
#  lines above are the only .idea/* exclusions)
