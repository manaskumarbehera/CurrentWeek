{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx jest *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(node scripts/*)",
      "Bash(./build.sh*)",
      "Bash(gh run *)",
      "Bash(gh release *)",
      "Bash(gh pr *)",
      "Bash(gh secret list*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git tag*)",
      "Bash(git merge*)",
      "Bash(gh secret set*)",
      "Bash(npm install*)",
      "Bash(npm ci*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git commit --no-verify*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)"
    ]
  },
  "_notes": [
    "Project-level Claude Code settings; checked in.",
    "Per-developer overrides go in .claude/settings.local.json (gitignored).",
    "Release flow: bump manifest.json + package.json, then push to main (or run the Release workflow with dry_run=false). See DOCUMENTATION/RELEASE.md."
  ]
}
