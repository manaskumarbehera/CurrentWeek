{
  "name": "currentweek",
  "version": "1.12",
  "description": "Manifest V3 browser extension that shows the current ISO 8601 week number, day, and date.",
  "main": "background.js",
  "type": "commonjs",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\" --ignore-path .prettierignore",
    "check:versions": "node scripts/check-version-consistency.cjs",
    "validate": "npm run check:versions && npm run lint && npm test",
    "dev": "vite",
    "vite:build": "vite build",
    "build": "./build.sh",
    "package:chrome": "./build.sh chrome",
    "package:edge": "./build.sh edge",
    "prepare": "husky"
  },
  "keywords": [
    "chrome-extension",
    "edge-extension",
    "manifest-v3",
    "iso-8601",
    "week-number"
  ],
  "author": "Manas Kumar Behera <behera.manas98@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "vite": "^5.4.21"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  }
}
